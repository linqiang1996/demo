.page {
  padding: 24rpx;
}

.hero {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f766e, #1e293b);
  color: #ffffff;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-toggle {
  color: #0f766e;
  font-size: 24rpx;
}

.section-note {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.8;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 18rpx;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
}

.value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.row:last-child {
  border-bottom: 0;
}

.row-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.row-meta {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.annual-value {
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
}

.warning-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff7ed;
  color: #9a3412;
}

.warning-line {
  font-size: 22rpx;
  line-height: 1.8;
}

.loading,
.error {
  padding: 28rpx;
  text-align: center;
  color: #475569;
}
